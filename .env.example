# .env.example
# Copy this file to .env and update with your actual values

# Kafka Configuration
KAFKA_BROKER_URL=kafka:9092
KAFKA_TOPIC_BINANCE=binance-topic
KAFKA_TOPIC_TRANSFORMED=transformed-topic
KAFKA_CONSUMER_GROUP_ID=binance-consumer-group

# Binance WebSocket Configuration
BINANCE_WS_BASE_URL=wss://stream.binance.com:9443/ws/
BINANCE_API_BASE_URL=https://api.binance.com/api/v3
BINANCE_SYMBOL=BTCUSDT
BINANCE_STREAM_TYPE=ticker

# Binance API Keys (for REST endpoints if needed)
# WARNING: Never commit real API keys to version control!
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Apache Pinot Configuration
PINOT_CONTROLLER_URL=http://pinot-controller:9000
PINOT_BROKER_URL=http://pinot-broker:8099
PINOT_SERVER_URL=http://pinot-server:8098
PINOT_TABLE_NAME=binance_realtime

# Data Visualization Configuration
SUPERSET_PORT=8088
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=admin123
SUPERSET_ADMIN_EMAIL=admin@superset.com
SUPERSET_SECRET_KEY=your_secret_key_here_make_it_long_and_random

# General Configuration
PYTHONUNBUFFERED=1
LOG_LEVEL=INFO
